{
  "expo": {
    "name": "Padho Label",
    "slug": "padho-label-v1-casubham",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8f9fa"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 10,
      "package": "com.padholabel.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f8f9fa"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Allow Padho Label to access your camera to scan barcodes and photograph ingredient labels.",
          "enableMicrophonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2ee7f060-c075-47f3-bb15-bcf7d3ae2789"
      }
    }
  }
}